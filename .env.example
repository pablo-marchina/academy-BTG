# === OBRIGATORIOS ===
GROQ_API_KEY=gsk_seu_token_aqui

# === ANBIMA (opcional, sem eles coleta so BCB + CVM + plataformas) ===
ANBIMA_CLIENT_ID=seu_client_id
ANBIMA_CLIENT_SECRET=seu_client_secret
ANBIMA_ACCESS_TOKEN=seu_access_token

# === TELEGRAM (opcional, sem eles nao ha alertas) ===
TELEGRAM_BOT_TOKEN=seu_bot_token
TELEGRAM_CHAT_ID=seu_chat_id

# === PIPELINE (defaults) ===
DATE_LOOKBACK_DAYS=7
REQUEST_TIMEOUT=60
